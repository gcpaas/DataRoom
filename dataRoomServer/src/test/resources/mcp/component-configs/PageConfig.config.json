    {
      "field": "basicConfig.background.fill",
      "type": "enum",
      "options": ["image", "color"],
      "description": "背景填充方式",
      "defaultValue": "color"
    },
    {
      "field": "chartList",
      "type": "array",
      "description": "图表组件配置，数组元素为ChartConfig结构"
    }
  ]
}
