{
  "componentName": "DrText",
  "displayName": "文本",
  "description": "文字、文本、数字",
  "fields": [
    {
      "field": "text",
      "type": "string",
      "description": "文本内容",
      "defaultValue": "文本占位符"
    },
    {
      "field": "textStyle.fontSize",
      "type": "number",
      "description": "字体大小(px)",
      "defaultValue": 14
    },
    {
      "field": "textStyle.fontWeight",
      "type": "string",
      "description": "字体粗细: 'normal' | 'bold' | '100'~'900'",
      "defaultValue": "normal"
    },
    {
      "field": "textStyle.fontFamily",
      "type": "string",
      "description": "字体族",
      "defaultValue": "Microsoft YaHei"
    },
    {
      "field": "textStyle.color",
      "type": "string",
      "description": "字体颜色",
      "defaultValue": "#333333"
    },
    {
      "field": "align",
      "type": "enum",
      "description": "对齐方式: left | center | right",
      "options": [
        "left",
        "center",
        "right"
      ],
      "defaultValue": "left"
    },
    {
      "field": "verticalAlign",
      "type": "enum",
      "description": "垂直对齐: top | center | bottom",
      "options": [
        "top",
        "center",
        "bottom"
      ],
      "defaultValue": "top"
    },
    {
      "field": "letterSpacing",
      "type": "number",
      "description": "文字间隔(px)",
      "defaultValue": 0
    },
    {
      "field": "background.enabled",
      "type": "boolean",
      "description": "是否启用背景样式",
      "defaultValue": false
    },
    {
      "field": "background.color",
      "type": "string",
      "description": "背景色",
      "defaultValue": "#007aff"
    },
    {
      "field": "background.borderRadius",
      "type": "number",
      "description": "圆角(px)",
      "defaultValue": 0
    },
    {
      "field": "background.border.width",
      "type": "number",
      "description": "边框宽度(px)",
      "defaultValue": 1
    },
    {
      "field": "background.border.style",
      "type": "enum",
      "description": "边框样式: solid | dashed | dotted | none",
      "options": [
        "solid",
        "dashed",
        "dotted",
        "none"
      ],
      "defaultValue": "solid"
    },
    {
      "field": "background.border.color",
      "type": "string",
      "description": "边框颜色",
      "defaultValue": "#eeeeee"
    },
    {
      "field": "ellipsis",
      "type": "boolean",
      "description": "文本溢出省略号",
      "defaultValue": false
    },
    {
      "field": "hyperlink.url",
      "type": "string",
      "description": "超链接URL",
      "defaultValue": ""
    },
    {
      "field": "hyperlink.openNewWindow",
      "type": "boolean",
      "description": "是否新开窗口",
      "defaultValue": false
    }
  ]
}
