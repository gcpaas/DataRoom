{
  "componentName": "DrImage",
  "displayName": "图片",
  "description": "图片、素材",
  "fields": [
    {
      "field": "id",
      "type": "string",
      "description": "唯一标识"
    },
    {
      "field": "i",
      "type": "string",
      "description": "唯一标识，仅仪表盘类型使用"
    },
    {
      "field": "type",
      "type": "string",
      "description": "组件类型",
      "defaultValue": "DrImage"
    },
    {
      "field": "title",
      "type": "string",
      "description": "组件显示的图层名称 或 卡片名称",
      "defaultValue": "图片"
    },
    {
      "field": "w",
      "type": "number",
      "description": "宽度或占用的份数",
      "defaultValue": 150
    },
    {
      "field": "h",
      "type": "number",
      "description": "高度或占用的份数",
      "defaultValue": 100
    },
    {
      "field": "x",
      "type": "number",
      "description": "x坐标或x轴份数",
      "defaultValue": 100
    },
    {
      "field": "y",
      "type": "number",
      "description": "y坐标或y轴份数",
      "defaultValue": 100
    },
    {
      "field": "z",
      "type": "number",
      "description": "组件层级、层级越大、越靠前显示",
      "defaultValue": 100
    },
    {
      "field": "rotateX",
      "type": "number",
      "description": "X轴旋转角度",
      "defaultValue": 0
    },
    {
      "field": "rotateY",
      "type": "number",
      "description": "Y轴旋转角度",
      "defaultValue": 0
    },
    {
      "field": "rotateZ",
      "type": "number",
      "description": "Z轴旋转角度",
      "defaultValue": 0
    },
    {
      "field": "hide",
      "type": "boolean",
      "description": "是否隐藏组件，true 时设计器与预览不渲染"
    },
    {
      "field": "children",
      "type": "array",
      "description": "子组件，仅在容器类组件有效"
    },
    {
      "field": "behaviors",
      "type": "object",
      "description": "图表交互",
      "defaultValue": {}
    },
    {
      "field": "dataset.code",
      "type": "string",
      "description": "数据集编码",
      "defaultValue": ""
    },
    {
      "field": "dataset.fields",
      "type": "object",
      "description": "字段绑定",
      "defaultValue": {}
    },
    {
      "field": "dataset.script",
      "type": "string",
      "description": "数据处理脚本",
      "defaultValue": ""
    },
    {
      "field": "dataset.params",
      "type": "object",
      "description": "数据集入参、如果数据集需要入参的话",
      "defaultValue": {}
    },
    {
      "field": "props.imageType",
      "type": "enum",
      "description": "图片类型: bitmap(位图) | svg(矢量图)",
      "options": [
        "bitmap",
        "svg"
      ],
      "defaultValue": "bitmap"
    },
    {
      "field": "props.url",
      "type": "string",
      "description": "图片地址(URL或相对路径)",
      "defaultValue": "/dataRoom/resource/image/placeholder.png"
    },
    {
      "field": "props.repeatMode",
      "type": "enum",
      "description": "图片重复/填充模式",
      "options": [
        "no-repeat-stretch",
        "no-repeat-contain",
        "no-repeat-center",
        "repeat",
        "repeat-x",
        "repeat-y"
      ],
      "defaultValue": "no-repeat-stretch"
    },
    {
      "field": "props.borderRadius",
      "type": "number",
      "description": "圆角(px)",
      "defaultValue": 0
    },
    {
      "field": "props.hyperlink.url",
      "type": "string",
      "description": "超链接URL",
      "defaultValue": ""
    },
    {
      "field": "props.hyperlink.openNewWindow",
      "type": "boolean",
      "description": "是否新开窗口",
      "defaultValue": false
    },
    {
      "field": "props.hyperlink.cursorPointer",
      "type": "boolean",
      "description": "是否显示手势光标(pointer)",
      "defaultValue": true
    }
  ]
}
