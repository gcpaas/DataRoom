{
  "componentName": "DrWordCloud",
  "displayName": "词云",
  "description": "词云、wordcloud、标签云、关键词、热词",
  "fields": [
    {
      "field": "global.padding",
      "type": "array",
      "description": "图表内边距 [上, 右, 下, 左] (px)",
      "defaultValue": [
        10,
        10,
        10,
        10
      ]
    },
    {
      "field": "wordStyle.fontFamily",
      "type": "string",
      "description": "字体",
      "defaultValue": "Microsoft YaHei"
    },
    {
      "field": "wordStyle.fontSizeRange",
      "type": "array",
      "description": "字号范围 [最小值, 最大值] (px)",
      "defaultValue": [
        14,
        60
      ]
    },
    {
      "field": "wordStyle.rotationRange",
      "type": "array",
      "description": "旋转角度范围 [最小角度, 最大角度] (度)",
      "defaultValue": [
        -45,
        45
      ]
    },
    {
      "field": "wordStyle.rotationStep",
      "type": "number",
      "description": "旋转角度步长（度），0表示任意角度",
      "defaultValue": 45
    },
    {
      "field": "wordStyle.colors",
      "type": "array",
      "description": "文字颜色列表，随机分配给词语",
      "defaultValue": [
        "#5470c6",
        "#91cc75",
        "#fac858",
        "#ee6666",
        "#73c0de",
        "#3ba272",
        "#fc8452",
        "#9a60b4"
      ]
    },
    {
      "field": "wordStyle.fontWeight",
      "type": "string",
      "description": "字体粗细",
      "defaultValue": "bold"
    },
    {
      "field": "shape.type",
      "type": "string",
      "description": "词云整体形状",
      "defaultValue": "circle"
    },
    {
      "field": "layout.gridSize",
      "type": "number",
      "description": "词语间距网格大小(px)，值越大间距越大",
      "defaultValue": 8
    },
    {
      "field": "layout.drawOutOfBound",
      "type": "boolean",
      "description": "是否允许词语超出画布边界绘制",
      "defaultValue": false
    },
    {
      "field": "tooltip.show",
      "type": "boolean",
      "description": "是否显示提示框",
      "defaultValue": true
    },
    {
      "field": "tooltip.backgroundColor",
      "type": "string",
      "description": "提示框背景颜色",
      "defaultValue": "rgba(50, 50, 50, 0.7)"
    },
    {
      "field": "tooltip.borderColor",
      "type": "string",
      "description": "提示框边框颜色",
      "defaultValue": "transparent"
    },
    {
      "field": "tooltip.textStyle.fontSize",
      "type": "number",
      "description": "fontSize",
      "defaultValue": 12
    },
    {
      "field": "tooltip.textStyle.color",
      "type": "string",
      "description": "color",
      "defaultValue": "#ffffff"
    },
    {
      "field": "emphasis.focus",
      "type": "string",
      "description": "高亮聚焦模式",
      "defaultValue": "self"
    },
    {
      "field": "emphasis.textStyle.shadowBlur",
      "type": "number",
      "description": "shadowBlur",
      "defaultValue": 10
    },
    {
      "field": "emphasis.textStyle.shadowColor",
      "type": "string",
      "description": "shadowColor",
      "defaultValue": "rgba(0, 0, 0, 0.3)"
    },
    {
      "field": "animation.enabled",
      "type": "boolean",
      "description": "是否启用布局动画",
      "defaultValue": true
    },
    {
      "field": "animation.duration",
      "type": "number",
      "description": "动画时长(ms)",
      "defaultValue": 1000
    },
    {
      "field": "animation.easing",
      "type": "string",
      "description": "动画缓动函数",
      "defaultValue": "cubicOut"
    }
  ]
}
