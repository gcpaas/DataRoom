{
  "componentName": "DrWordCloud",
  "displayName": "词云",
  "description": "词云、wordcloud、标签云、关键词、热词",
  "fields": [
    {
      "field": "id",
      "type": "string",
      "description": "唯一标识，必填"
    },
    {
      "field": "i",
      "type": "string",
      "description": "唯一标识，当pageType=page时必填，默认与id保持一致"
    },
    {
      "field": "type",
      "type": "string",
      "description": "组件类型",
      "defaultValue": "DrWordCloud"
    },
    {
      "field": "title",
      "type": "string",
      "description": "组件显示的图层名称 或 卡片名称",
      "defaultValue": "词云"
    },
    {
      "field": "w",
      "type": "number",
      "description": "宽度或占用的份数",
      "defaultValue": 400
    },
    {
      "field": "h",
      "type": "number",
      "description": "高度或占用的份数",
      "defaultValue": 300
    },
    {
      "field": "x",
      "type": "number",
      "description": "x坐标或x轴份数",
      "defaultValue": 100
    },
    {
      "field": "y",
      "type": "number",
      "description": "y坐标或y轴份数",
      "defaultValue": 100
    },
    {
      "field": "z",
      "type": "number",
      "description": "组件层级、层级越大、越靠前显示",
      "defaultValue": 100
    },
    {
      "field": "rotateX",
      "type": "number",
      "description": "X轴旋转角度",
      "defaultValue": 0
    },
    {
      "field": "rotateY",
      "type": "number",
      "description": "Y轴旋转角度",
      "defaultValue": 0
    },
    {
      "field": "rotateZ",
      "type": "number",
      "description": "Z轴旋转角度",
      "defaultValue": 0
    },
    {
      "field": "hide",
      "type": "boolean",
      "description": "是否隐藏组件，true 时设计器与预览不渲染"
    },
    {
      "field": "children",
      "type": "array",
      "description": "子组件，仅在容器类组件有效"
    },
    {
      "field": "behaviors",
      "type": "object",
      "description": "图表交互",
      "defaultValue": {}
    },
    {
      "field": "dataset.code",
      "type": "string",
      "description": "数据集编码",
      "defaultValue": ""
    },
    {
      "field": "dataset.fields",
      "type": "object",
      "description": "字段绑定",
      "defaultValue": {}
    },
    {
      "field": "dataset.script",
      "type": "string",
      "description": "数据处理脚本",
      "defaultValue": ""
    },
    {
      "field": "dataset.params",
      "type": "object",
      "description": "数据集入参、如果数据集需要入参的话",
      "defaultValue": {}
    },
    {
      "field": "props.global.padding",
      "type": "array",
      "description": "图表内边距 [上, 右, 下, 左] (px)",
      "defaultValue": [
        10,
        10,
        10,
        10
      ]
    },
    {
      "field": "props.wordStyle.fontFamily",
      "type": "string",
      "description": "字体",
      "defaultValue": "Microsoft YaHei"
    },
    {
      "field": "props.wordStyle.fontSizeRange",
      "type": "array",
      "description": "字号范围 [最小值, 最大值] (px)",
      "defaultValue": [
        14,
        60
      ]
    },
    {
      "field": "props.wordStyle.rotationRange",
      "type": "array",
      "description": "旋转角度范围 [最小角度, 最大角度] (度)",
      "defaultValue": [
        -45,
        45
      ]
    },
    {
      "field": "props.wordStyle.rotationStep",
      "type": "number",
      "description": "旋转角度步长（度），0表示任意角度",
      "defaultValue": 45
    },
    {
      "field": "props.wordStyle.colors",
      "type": "array",
      "description": "文字颜色列表，随机分配给词语",
      "defaultValue": [
        "#5470c6",
        "#91cc75",
        "#fac858",
        "#ee6666",
        "#73c0de",
        "#3ba272",
        "#fc8452",
        "#9a60b4"
      ]
    },
    {
      "field": "props.wordStyle.fontWeight",
      "type": "string",
      "description": "字体粗细",
      "defaultValue": "bold"
    },
    {
      "field": "props.shape.type",
      "type": "string",
      "description": "词云整体形状",
      "defaultValue": "circle"
    },
    {
      "field": "props.layout.gridSize",
      "type": "number",
      "description": "词语间距网格大小(px)，值越大间距越大",
      "defaultValue": 8
    },
    {
      "field": "props.layout.drawOutOfBound",
      "type": "boolean",
      "description": "是否允许词语超出画布边界绘制",
      "defaultValue": false
    },
    {
      "field": "props.tooltip.show",
      "type": "boolean",
      "description": "是否显示提示框",
      "defaultValue": true
    },
    {
      "field": "props.tooltip.backgroundColor",
      "type": "string",
      "description": "提示框背景颜色",
      "defaultValue": "rgba(50, 50, 50, 0.7)"
    },
    {
      "field": "props.tooltip.borderColor",
      "type": "string",
      "description": "提示框边框颜色",
      "defaultValue": "transparent"
    },
    {
      "field": "props.tooltip.textStyle.fontSize",
      "type": "number",
      "description": "fontSize",
      "defaultValue": 12
    },
    {
      "field": "props.tooltip.textStyle.color",
      "type": "string",
      "description": "color",
      "defaultValue": "#ffffff"
    },
    {
      "field": "props.emphasis.focus",
      "type": "string",
      "description": "高亮聚焦模式",
      "defaultValue": "self"
    },
    {
      "field": "props.emphasis.textStyle.shadowBlur",
      "type": "number",
      "description": "shadowBlur",
      "defaultValue": 10
    },
    {
      "field": "props.emphasis.textStyle.shadowColor",
      "type": "string",
      "description": "shadowColor",
      "defaultValue": "rgba(0, 0, 0, 0.3)"
    },
    {
      "field": "props.animation.enabled",
      "type": "boolean",
      "description": "是否启用布局动画",
      "defaultValue": true
    },
    {
      "field": "props.animation.duration",
      "type": "number",
      "description": "动画时长(ms)",
      "defaultValue": 1000
    },
    {
      "field": "props.animation.easing",
      "type": "string",
      "description": "动画缓动函数",
      "defaultValue": "cubicOut"
    }
  ]
}
