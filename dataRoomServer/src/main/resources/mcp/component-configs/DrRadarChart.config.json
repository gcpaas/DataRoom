{
  "componentName": "DrRadarChart",
  "displayName": "雷达图",
  "description": "雷达图、radar、蛛网图、能力图",
  "fields": [
    {
      "field": "id",
      "type": "string",
      "description": "唯一标识，必填"
    },
    {
      "field": "i",
      "type": "string",
      "description": "唯一标识，当pageType=page时必填，默认与id保持一致"
    },
    {
      "field": "type",
      "type": "string",
      "description": "组件类型",
      "defaultValue": "DrRadarChart"
    },
    {
      "field": "title",
      "type": "string",
      "description": "组件显示的图层名称 或 卡片名称",
      "defaultValue": "雷达图"
    },
    {
      "field": "w",
      "type": "number",
      "description": "宽度或占用的份数",
      "defaultValue": 400
    },
    {
      "field": "h",
      "type": "number",
      "description": "高度或占用的份数",
      "defaultValue": 400
    },
    {
      "field": "x",
      "type": "number",
      "description": "x坐标或x轴份数",
      "defaultValue": 100
