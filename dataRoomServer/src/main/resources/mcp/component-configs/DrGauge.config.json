{
  "componentName": "DrGauge",
  "displayName": "仪表盘",
  "description": "仪表盘、gauge、速度计、进度盘、刻度盘、KPI",
  "fields": [
    {
      "field": "global.padding",
      "type": "array",
      "description": "图表内边距 [上, 右, 下, 左] (px)",
      "defaultValue": [
        10,
        10,
        10,
        10
      ]
    },
    {
      "field": "gauge.startAngle",
      "type": "number",
      "description": "起始角度（正上方为90，顺时针减小）",
      "defaultValue": 225
    },
    {
      "field": "gauge.endAngle",
      "type": "number",
      "description": "结束角度",
      "defaultValue": -45
    },
    {
      "field": "gauge.min",
      "type": "number",
      "description": "最小刻度值",
      "defaultValue": 0
    },
    {
      "field": "gauge.max",
      "type": "number",
      "description": "最大刻度值",
      "defaultValue": 100
    },
    {
      "field": "gauge.splitNumber",
      "type": "number",
      "description": "仪表盘刻度分割段数",
      "defaultValue": 10
    },
    {
      "field": "gauge.clockwise",
      "type": "boolean",
      "description": "是否顺时针增长",
      "defaultValue": true
    },
    {
      "field": "gauge.radius",
      "type": "string",
      "description": "仪表盘半径（百分比或像素值）",
      "defaultValue": "75%"
    },
    {
      "field": "gauge.center",
      "type": "array",
      "description": "中心位置 [x, y]",
      "defaultValue": [
        "50%",
        "55%"
      ]
    },
    {
      "field": "axisLine.show",
      "type": "boolean",
      "description": "是否显示轴线",
      "defaultValue": true
    },
    {
      "field": "axisLine.width",
      "type": "number",
      "description": "轴线宽度(px)",
      "defaultValue": 20
    },
    {
      "field": "axisLine.roundCap",
      "type": "boolean",
      "description": "轴线两端是否显示为圆形",
      "defaultValue": false
    },
    {
      "field": "axisLine.colors",
      "type": "array",
      "description": "轴线渐变色段 [[位置, 颜色], ...]，位置为0~1之间的值",
      "defaultValue": [
        [
          0.3,
          "#91cc75"
        ],
        [
          0.7,
          "#fac858"
        ],
        [
          1,
          "#ee6666"
        ]
      ]
    },
    {
      "field": "axisTick.show",
      "type": "boolean",
      "description": "是否显示刻度线",
      "defaultValue": true
    },
    {
      "field": "axisTick.splitNumber",
      "type": "number",
      "description": "每个分割段内的刻度数",
      "defaultValue": 5
    },
    {
      "field": "axisTick.length",
      "type": "number",
      "description": "刻度线长度(px)",
      "defaultValue": 6
    },
    {
      "field": "axisTick.color",
      "type": "string",
      "description": "刻度线颜色，auto表示自动取轴线颜色",
      "defaultValue": "auto"
    },
    {
      "field": "axisTick.width",
      "type": "number",
      "description": "刻度线宽度(px)",
      "defaultValue": 1
    },
    {
      "field": "splitLine.show",
      "type": "boolean",
      "description": "是否显示分割线",
      "defaultValue": true
    },
    {
      "field": "splitLine.length",
      "type": "number",
      "description": "分割线长度(px)",
      "defaultValue": 12
    },
    {
      "field": "splitLine.color",
      "type": "string",
      "description": "分割线颜色，auto表示自动取轴线颜色",
      "defaultValue": "auto"
    },
    {
      "field": "splitLine.width",
      "type": "number",
      "description": "分割线宽度(px)",
      "defaultValue": 2
    },
    {
      "field": "axisLabel.show",
      "type": "boolean",
      "description": "是否显示刻度标签",
      "defaultValue": true
    },
    {
      "field": "axisLabel.fontSize",
      "type": "number",
      "description": "字号(px)",
      "defaultValue": 12
    },
    {
      "field": "axisLabel.color",
      "type": "string",
      "description": "标签颜色",
      "defaultValue": "#999999"
    },
    {
      "field": "axisLabel.distance",
      "type": "number",
      "description": "标签到轴线的距离(px)",
      "defaultValue": 15
    },
    {
      "field": "axisLabel.formatter",
      "type": "string",
      "description": "标签格式化模板，{value}为数值占位符",
      "defaultValue": "{value}"
    },
    {
      "field": "pointer.show",
      "type": "boolean",
      "description": "是否显示指针",
      "defaultValue": true
    },
    {
      "field": "pointer.length",
      "type": "string",
      "description": "指针长度（百分比相对于半径）",
      "defaultValue": "60%"
    },
    {
      "field": "pointer.width",
      "type": "number",
      "description": "指针宽度(px)",
      "defaultValue": 6
    },
    {
      "field": "pointer.color",
      "type": "string",
      "description": "指针颜色，auto表示跟随轴线颜色",
      "defaultValue": "auto"
    },
    {
      "field": "pointer.type",
      "type": "enum",
      "description": "指针形状类型",
      "options": [
        "default",
        "arrow",
        "triangle",
        "rect"
      ],
      "defaultValue": "default"
    },
    {
      "field": "anchor.show",
      "type": "boolean",
      "description": "是否显示锚点",
      "defaultValue": true
    },
    {
      "field": "anchor.size",
      "type": "number",
      "description": "锚点大小(px)",
      "defaultValue": 10
    },
    {
      "field": "anchor.color",
      "type": "string",
      "description": "锚点颜色",
      "defaultValue": "#5470c6"
    },
    {
      "field": "anchor.borderWidth",
      "type": "number",
      "description": "锚点边框宽度(px)",
      "defaultValue": 2
    },
    {
      "field": "anchor.borderColor",
      "type": "string",
      "description": "锚点边框颜色",
      "defaultValue": "#5470c6"
    },
    {
      "field": "progress.show",
      "type": "boolean",
      "description": "是否显示进度条",
      "defaultValue": false
    },
    {
      "field": "progress.width",
      "type": "number",
      "description": "进度条宽度(px)，默认与轴线同宽",
      "defaultValue": 20
    },
    {
      "field": "progress.roundCap",
      "type": "boolean",
      "description": "进度条两端是否圆形",
      "defaultValue": false
    },
    {
      "field": "progress.color",
      "type": "string",
      "description": "进度条颜色",
      "defaultValue": "#5470c6"
    },
    {
      "field": "detail.show",
      "type": "boolean",
      "description": "是否显示数值",
      "defaultValue": true
    },
    {
      "field": "detail.fontSize",
      "type": "number",
      "description": "数值字号(px)",
      "defaultValue": 28
    },
    {
      "field": "detail.color",
      "type": "string",
      "description": "数值颜色，auto表示跟随轴线颜色",
      "defaultValue": "auto"
    },
    {
      "field": "detail.fontWeight",
      "type": "enum",
      "description": "数值字重",
      "options": [
        "normal",
        "bold",
        300,
        500,
        800
      ],
      "defaultValue": "bold"
    },
    {
      "field": "detail.format",
      "type": "enum",
      "description": "数值格式化方式",
      "options": [
        "value",
        "percent",
        "integer",
        "float1",
        "float2"
      ],
      "defaultValue": "value"
    },
    {
      "field": "detail.offsetY",
      "type": "number",
      "description": "数值纵向偏移(%)，正值向下",
      "defaultValue": 60
    },
    {
      "field": "detail.prefix",
      "type": "string",
      "description": "数值前缀文本",
      "defaultValue": ""
    },
    {
      "field": "detail.suffix",
      "type": "string",
      "description": "数值后缀文本",
      "defaultValue": ""
    },
    {
      "field": "title.show",
      "type": "boolean",
      "description": "是否显示标题文字",
      "defaultValue": true
    },
    {
      "field": "title.text",
      "type": "string",
      "description": "固定标题文字（优先使用数据集中的标题字段）",
      "defaultValue": ""
    },
    {
      "field": "title.fontSize",
      "type": "number",
      "description": "标题字号(px)",
      "defaultValue": 14
    },
    {
      "field": "title.color",
      "type": "string",
      "description": "标题颜色",
      "defaultValue": "#999999"
    },
    {
      "field": "title.fontWeight",
      "type": "enum",
      "description": "标题字重",
      "options": [
        "normal",
        "bold",
        300,
        500,
        800
      ],
      "defaultValue": "normal"
    },
    {
      "field": "title.offsetY",
      "type": "number",
      "description": "标题纵向偏移(%)，正值向下",
      "defaultValue": 75
    },
    {
      "field": "animation.enabled",
      "type": "boolean",
      "description": "是否启用动画",
      "defaultValue": true
    },
    {
      "field": "animation.duration",
      "type": "number",
      "description": "动画时长(ms)",
      "defaultValue": 1000
    },
    {
      "field": "animation.easing",
      "type": "enum",
      "description": "动画缓动函数",
      "options": [
        "linear",
        "cubicOut",
        "elasticOut",
        "bounceOut"
      ],
      "defaultValue": "cubicOut"
    }
  ]
}
