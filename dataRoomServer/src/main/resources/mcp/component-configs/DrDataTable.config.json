{
  "componentName": "DrDataTable",
  "displayName": "数据表格",
  "description": "数据表格、明细表、列表、分页、搜索、排序、设备清单、告警记录",
  "fields": [
    {
      "field": "id",
      "type": "string",
      "description": "唯一标识"
    },
    {
      "field": "i",
      "type": "string",
      "description": "唯一标识，仅仪表盘类型使用"
    },
    {
      "field": "type",
      "type": "string",
      "description": "组件类型",
      "defaultValue": "DrDataTable"
    },
    {
      "field": "title",
      "type": "string",
      "description": "组件显示的图层名称 或 卡片名称",
      "defaultValue": "数据表格"
    },
    {
      "field": "w",
      "type": "number",
      "description": "宽度或占用的份数",
      "defaultValue": 640
    },
    {
      "field": "h",
      "type": "number",
      "description": "高度或占用的份数",
      "defaultValue": 360
    },
    {
      "field": "x",
      "type": "number",
      "description": "x坐标或x轴份数",
      "defaultValue": 0
    },
    {
      "field": "y",
      "type": "number",
      "description": "y坐标或y轴份数",
      "defaultValue": 0
    },
    {
      "field": "z",
      "type": "number",
      "description": "组件层级、层级越大、越靠前显示",
      "defaultValue": 0
    },
    {
      "field": "rotateX",
      "type": "number",
      "description": "X轴旋转角度",
      "defaultValue": 0
    },
    {
      "field": "rotateY",
      "type": "number",
      "description": "Y轴旋转角度",
      "defaultValue": 0
    },
    {
      "field": "rotateZ",
      "type": "number",
      "description": "Z轴旋转角度",
      "defaultValue": 0
    },
    {
      "field": "hide",
      "type": "boolean",
      "description": "是否隐藏组件，true 时设计器与预览不渲染"
    },
    {
      "field": "children",
      "type": "array",
      "description": "子组件，仅在容器类组件有效"
    },
    {
      "field": "behaviors",
      "type": "object",
      "description": "图表交互",
      "defaultValue": {}
    },
    {
      "field": "dataset.code",
      "type": "string",
      "description": "数据集编码",
      "defaultValue": ""
    },
    {
      "field": "dataset.fields",
      "type": "object",
      "description": "字段绑定",
      "defaultValue": {}
    },
    {
      "field": "dataset.script",
      "type": "string",
      "description": "数据处理脚本",
      "defaultValue": ""
    },
    {
      "field": "dataset.params",
      "type": "object",
      "description": "数据集入参、如果数据集需要入参的话",
      "defaultValue": {}
    },
    {
      "field": "props.global.padding",
      "type": "array",
      "description": "padding",
      "defaultValue": [
        0,
        0,
        0,
        0
      ]
    },
    {
      "field": "props.global.backgroundColor",
      "type": "string",
      "description": "backgroundColor",
      "defaultValue": "rgba(0, 0, 0, 0)"
    },
    {
      "field": "props.global.borderColor",
      "type": "string",
      "description": "borderColor",
      "defaultValue": "rgba(0, 0, 0, 0)"
    },
    {
      "field": "props.global.borderWidth",
      "type": "number",
      "description": "borderWidth",
      "defaultValue": 0
    },
    {
      "field": "props.global.borderRadius",
      "type": "number",
      "description": "borderRadius",
      "defaultValue": 6
    },
    {
      "field": "props.table.autoColumns",
      "type": "boolean",
      "description": "autoColumns",
      "defaultValue": true
    },
    {
      "field": "props.table.columns",
      "type": "array",
      "description": "columns",
      "defaultValue": [
        {
          "field": "name",
          "label": "名称",
          "width": 160,
          "align": "left",
          "format": "text",
          "visible": true
        },
        {
          "field": "value",
          "label": "数值",
          "width": 120,
          "align": "right",
          "format": "thousand",
          "visible": true
        },
        {
          "field": "status",
          "label": "状态",
          "width": 120,
          "align": "center",
          "format": "text",
          "visible": true
        }
      ]
    },
    {
      "field": "props.table.rowKey",
      "type": "string",
      "description": "rowKey",
      "defaultValue": ""
    },
    {
      "field": "props.table.size",
      "type": "enum",
      "description": "size",
      "options": [
        "large",
        "default",
        "small"
      ],
      "defaultValue": "default"
    },
    {
      "field": "props.table.border",
      "type": "boolean",
      "description": "border",
      "defaultValue": false
    },
    {
      "field": "props.table.stripe",
      "type": "boolean",
      "description": "stripe",
      "defaultValue": true
    },
    {
      "field": "props.table.fit",
      "type": "boolean",
      "description": "fit",
      "defaultValue": true
    },
    {
      "field": "props.table.showIndex",
      "type": "boolean",
      "description": "showIndex",
      "defaultValue": false
    },
    {
      "field": "props.table.emptyText",
      "type": "string",
      "description": "emptyText",
      "defaultValue": "暂无数据"
    },
    {
      "field": "props.headerStyle.height",
      "type": "number",
      "description": "height",
      "defaultValue": 42
    },
    {
      "field": "props.headerStyle.backgroundColor",
      "type": "string",
      "description": "backgroundColor",
      "defaultValue": "#f5f7fa"
    },
    {
      "field": "props.headerStyle.color",
      "type": "string",
      "description": "color",
      "defaultValue": "#303133"
    },
    {
      "field": "props.headerStyle.fontSize",
      "type": "number",
      "description": "fontSize",
      "defaultValue": 14
    },
    {
      "field": "props.headerStyle.fontWeight",
      "type": "enum",
      "description": "fontWeight",
      "options": [
        "normal",
        "bold",
        "bolder"
      ],
      "defaultValue": "bold"
    },
    {
      "field": "props.headerStyle.textAlign",
      "type": "enum",
      "description": "textAlign",
      "options": [
        "left",
        "center",
        "right"
      ],
      "defaultValue": "left"
    },
    {
      "field": "props.rowStyle.height",
      "type": "number",
      "description": "height",
      "defaultValue": 40
    },
    {
      "field": "props.rowStyle.backgroundColor",
      "type": "string",
      "description": "backgroundColor",
      "defaultValue": "rgba(0, 0, 0, 0)"
    },
    {
      "field": "props.rowStyle.stripeBackgroundColor",
      "type": "string",
      "description": "stripeBackgroundColor",
      "defaultValue": "#fafafa"
    },
    {
      "field": "props.rowStyle.hoverBackgroundColor",
      "type": "string",
      "description": "hoverBackgroundColor",
      "defaultValue": "#ecf5ff"
    },
    {
      "field": "props.rowStyle.borderColor",
      "type": "string",
      "description": "borderColor",
      "defaultValue": "#ebeef5"
    },
    {
      "field": "props.cellStyle.color",
      "type": "string",
      "description": "color",
      "defaultValue": "#606266"
    },
    {
      "field": "props.cellStyle.fontSize",
      "type": "number",
      "description": "fontSize",
      "defaultValue": 14
    },
    {
      "field": "props.cellStyle.fontWeight",
      "type": "enum",
      "description": "fontWeight",
      "options": [
        "normal",
        "bold",
        "bolder"
      ],
      "defaultValue": "normal"
    },
    {
      "field": "props.cellStyle.padding",
      "type": "array",
      "description": "padding",
      "defaultValue": [
        8,
        12,
        8,
        12
      ]
    },
    {
      "field": "props.cellStyle.overflow",
      "type": "enum",
      "description": "overflow",
      "options": [
        "ellipsis",
        "wrap",
        "clip"
      ],
      "defaultValue": "ellipsis"
    },
    {
      "field": "props.cellStyle.showTooltip",
      "type": "boolean",
      "description": "showTooltip",
      "defaultValue": true
    },
    {
      "field": "props.search.show",
      "type": "boolean",
      "description": "show",
      "defaultValue": false
    },
    {
      "field": "props.search.placeholder",
      "type": "string",
      "description": "placeholder",
      "defaultValue": "搜索"
    },
    {
      "field": "props.search.fields",
      "type": "array",
      "description": "fields",
      "defaultValue": []
    },
    {
      "field": "props.search.debounce",
      "type": "number",
      "description": "debounce",
      "defaultValue": 200
    },
    {
      "field": "props.sort.enabled",
      "type": "boolean",
      "description": "enabled",
      "defaultValue": true
    },
    {
      "field": "props.sort.defaultField",
      "type": "string",
      "description": "defaultField",
      "defaultValue": ""
    },
    {
      "field": "props.sort.defaultOrder",
      "type": "enum",
      "description": "defaultOrder",
      "options": [
        "ascending",
        "descending",
        "none"
      ],
      "defaultValue": "none"
    },
    {
      "field": "props.pagination.show",
      "type": "boolean",
      "description": "show",
      "defaultValue": true
    },
    {
      "field": "props.pagination.pageSize",
      "type": "number",
      "description": "pageSize",
      "defaultValue": 10
    },
    {
      "field": "props.pagination.pageSizes",
      "type": "array",
      "description": "pageSizes",
      "defaultValue": [
        10,
        20,
        50,
        100
      ]
    },
    {
      "field": "props.pagination.layout",
      "type": "enum",
      "description": "layout",
      "options": [
        "prev, pager, next",
        "total, prev, pager, next",
        "sizes, prev, pager, next"
      ],
      "defaultValue": "prev, pager, next"
    },
    {
      "field": "props.pagination.position",
      "type": "enum",
      "description": "position",
      "options": [
        "bottomLeft",
        "bottomCenter",
        "bottomRight",
        "topRight"
      ],
      "defaultValue": "bottomRight"
    },
    {
      "field": "props.formatting.defaultNumberFormat",
      "type": "enum",
      "description": "defaultNumberFormat",
      "options": [
        "text",
        "value",
        "integer",
        "float1",
        "float2",
        "percent",
        "percent0",
        "percent1",
        "percent2",
        "thousand",
        "currency",
        "date"
      ],
      "defaultValue": "value"
    },
    {
      "field": "props.formatting.dateFormat",
      "type": "string",
      "description": "dateFormat",
      "defaultValue": "YYYY-MM-DD HH:mm:ss"
    },
    {
      "field": "props.formatting.nullText",
      "type": "string",
      "description": "nullText",
      "defaultValue": "--"
    }
  ]
}
