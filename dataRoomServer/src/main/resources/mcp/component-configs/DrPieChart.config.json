    {
      "field": "y",
      "type": "number",
      "description": "y坐标或y轴份数",
      "defaultValue": 100
    },
    {
      "field": "z",
      "type": "number",
      "description": "组件层级、层级越大、越靠前显示",
      "defaultValue": 100
