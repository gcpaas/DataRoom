{
  "componentName": "DrAlarmImage",
  "displayName": "告警图",
  "description": "告警、图片、阈值、指标、状态、区间",
  "fields": [
    {
      "field": "id",
      "type": "string",
      "description": "唯一标识"
    },
    {
      "field": "i",
      "type": "string",
      "description": "唯一标识，仅仪表盘类型使用"
    },
    {
      "field": "type",
      "type": "string",
      "description": "组件类型",
      "defaultValue": "DrAlarmImage"
    },
    {
      "field": "title",
      "type": "string",
      "description": "组件显示的图层名称 或 卡片名称",
      "defaultValue": "告警图"
    },
    {
      "field": "w",
      "type": "number",
      "description": "宽度或占用的份数",
      "defaultValue": 220
    },
    {
      "field": "h",
      "type": "number",
      "description": "高度或占用的份数",
      "defaultValue": 180
    },
    {
      "field": "x",
      "type": "number",
      "description": "x坐标或x轴份数",
      "defaultValue": 100
    },
    {
      "field": "y",
      "type": "number",
      "description": "y坐标或y轴份数",
      "defaultValue": 100
    },
    {
      "field": "z",
      "type": "number",
      "description": "组件层级、层级越大、越靠前显示",
      "defaultValue": 100
    },
    {
      "field": "rotateX",
      "type": "number",
      "description": "X轴旋转角度",
      "defaultValue": 0
    },
    {
      "field": "rotateY",
      "type": "number",
      "description": "Y轴旋转角度",
      "defaultValue": 0
    },
    {
      "field": "rotateZ",
      "type": "number",
      "description": "Z轴旋转角度",
      "defaultValue": 0
    },
    {
      "field": "hide",
      "type": "boolean",
      "description": "是否隐藏组件，true 时设计器与预览不渲染"
    },
    {
      "field": "children",
      "type": "array",
      "description": "子组件，仅在容器类组件有效"
    },
    {
      "field": "behaviors",
      "type": "object",
      "description": "图表交互",
      "defaultValue": {}
    },
    {
      "field": "dataset.code",
      "type": "string",
      "description": "数据集编码",
      "defaultValue": ""
    },
    {
      "field": "dataset.fields",
      "type": "object",
      "description": "字段绑定",
      "defaultValue": {}
    },
    {
      "field": "dataset.script",
      "type": "string",
      "description": "数据处理脚本",
      "defaultValue": ""
    },
    {
      "field": "dataset.params",
      "type": "object",
      "description": "数据集入参、如果数据集需要入参的话",
      "defaultValue": {}
    },
    {
      "field": "props.value.show",
      "type": "boolean",
      "description": "show",
      "defaultValue": true
    },
    {
      "field": "props.value.defaultValue",
      "type": "number",
      "description": "defaultValue",
      "defaultValue": 95
    },
    {
      "field": "props.value.format",
      "type": "enum",
      "description": "format",
      "options": [
        "value",
        "integer",
        "float1",
        "float2",
        "percent",
        "thousand",
        "currency"
      ],
      "defaultValue": "integer"
    },
    {
      "field": "props.value.decimalPlaces",
      "type": "number",
      "description": "decimalPlaces",
      "defaultValue": 0
    },
    {
      "field": "props.value.thousandSeparator",
      "type": "boolean",
      "description": "thousandSeparator",
      "defaultValue": false
    },
    {
      "field": "props.value.prefix",
      "type": "string",
      "description": "prefix",
      "defaultValue": ""
    },
    {
      "field": "props.value.suffix",
      "type": "string",
      "description": "suffix",
      "defaultValue": ""
    },
    {
      "field": "props.value.emptyText",
      "type": "string",
      "description": "emptyText",
      "defaultValue": "--"
    },
    {
      "field": "props.value.fontSize",
      "type": "number",
      "description": "fontSize",
      "defaultValue": 28
    },
    {
      "field": "props.value.color",
      "type": "string",
      "description": "color",
      "defaultValue": "var(--el-text-color-primary)"
    },
    {
      "field": "props.value.fontWeight",
      "type": "enum",
      "description": "fontWeight",
      "options": [
        "normal",
        "bold",
        "bolder"
      ],
      "defaultValue": "bold"
    },
    {
      "field": "props.value.lineHeight",
      "type": "number",
      "description": "lineHeight",
      "defaultValue": 1
    },
    {
      "field": "props.image.defaultItemId",
      "type": "string",
      "description": "defaultItemId",
      "defaultValue": "normal"
    },
    {
      "field": "props.image.repeatMode",
      "type": "enum",
      "description": "repeatMode",
      "options": [
        "no-repeat-stretch",
        "no-repeat-contain",
        "no-repeat-center",
        "repeat",
        "repeat-x",
        "repeat-y"
      ],
      "defaultValue": "no-repeat-contain"
    },
    {
      "field": "props.image.borderRadius",
      "type": "number",
      "description": "borderRadius",
      "defaultValue": 0
    },
    {
      "field": "props.image.items",
      "type": "array",
      "description": "items",
      "defaultValue": [
        {
          "id": "normal",
          "name": "正常",
          "url": "/dataRoom/resource/image/placeholder.png",
          "condition": "",
          "enabled": true
        },
        {
          "id": "warning",
          "name": "预警",
          "url": "/dataRoom/resource/image/placeholder.png",
          "condition": "100 > x > 90",
          "enabled": true
        },
        {
          "id": "danger",
          "name": "异常",
          "url": "/dataRoom/resource/image/placeholder.png",
          "condition": "x >= 100",
          "enabled": true
        }
      ]
    },
    {
      "field": "props.layout.direction",
      "type": "enum",
      "description": "direction",
      "options": [
        "vertical",
        "horizontal"
      ],
      "defaultValue": "vertical"
    },
    {
      "field": "props.layout.imageSize",
      "type": "enum",
      "description": "imageSize",
      "options": [
        "auto",
        "contain"
      ],
      "defaultValue": "contain"
    },
    {
      "field": "props.layout.gap",
      "type": "number",
      "description": "gap",
      "defaultValue": 8
    },
    {
      "field": "props.layout.horizontalAlign",
      "type": "enum",
      "description": "horizontalAlign",
      "options": [
        "left",
        "center",
        "right"
      ],
      "defaultValue": "center"
    },
    {
      "field": "props.layout.verticalAlign",
      "type": "enum",
      "description": "verticalAlign",
      "options": [
        "top",
        "center",
        "bottom"
      ],
      "defaultValue": "center"
    },
    {
      "field": "props.animation.enabled",
      "type": "boolean",
      "description": "enabled",
      "defaultValue": true
    },
    {
      "field": "props.animation.duration",
      "type": "number",
      "description": "duration",
      "defaultValue": 200
    }
  ]
}
