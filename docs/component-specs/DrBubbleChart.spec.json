{
  "componentName": "DrBubbleChart",
  "title": "气泡图",
  "description": "气泡图通过散点的位置和大小展示多维数据关系。X/Y轴表示两个维度的数值，气泡大小映射第三维数据，颜色映射分类或第四维数据。适合多维数据分析和聚类可视化。",
  "defaultSize": {
    "w": 450,
    "h": 350
  },
  "propsInterface": {
    "global": {
      "description": "全局配置",
      "properties": {
        "padding": {
          "type": "[number, number, number, number]",
          "description": "图表内边距 [上, 右, 下, 左] (px)",
          "default": [40, 30, 30, 50]
        }
      }
    },
    "xAxis": {
      "description": "X轴配置",
      "properties": {
        "show": { "type": "boolean", "description": "是否显示", "default": true },
        "name": { "type": "string", "description": "轴名称", "default": "" },
        "type": {
          "type": "string",
          "description": "数据类型",
          "enum": ["value", "category", "time"],
          "default": "value"
        },
        "range": {
          "type": "object",
          "description": "显示范围",
          "properties": {
            "auto": { "type": "boolean", "default": true },
            "min": { "type": "number", "default": 0 },
            "max": { "type": "number", "default": 100 }
          }
        },
        "axisLine": {
          "type": "object",
          "description": "轴线",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "color": { "type": "string", "default": "#cccccc" },
            "width": { "type": "number", "default": 1 }
          }
        },
        "axisLabel": {
          "type": "object",
          "description": "轴标签",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "fontSize": { "type": "number", "default": 12 },
            "color": { "type": "string", "default": "#999999" },
            "fontWeight": { "type": "string", "default": "normal" },
            "fontFamily": { "type": "string", "default": "Microsoft YaHei" },
            "rotate": { "type": "number", "default": 0 }
          }
        },
        "axisTick": {
          "type": "object",
          "description": "刻度线",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "length": { "type": "number", "default": 5 },
            "color": { "type": "string", "default": "#cccccc" }
          }
        },
        "splitLine": {
          "type": "object",
          "description": "网格线",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "color": { "type": "string", "default": "#eeeeee" },
            "width": { "type": "number", "default": 1 },
            "type": { "type": "string", "enum": ["solid", "dashed", "dotted"], "default": "dashed" }
          }
        }
      }
    },
    "yAxis": {
      "description": "Y轴配置",
      "properties": {
        "show": { "type": "boolean", "description": "是否显示", "default": true },
        "name": { "type": "string", "description": "轴名称", "default": "" },
        "range": {
          "type": "object",
          "description": "显示范围",
          "properties": {
            "auto": { "type": "boolean", "default": true },
            "min": { "type": "number", "default": 0 },
            "max": { "type": "number", "default": 100 }
          }
        },
        "axisLine": {
          "type": "object",
          "description": "轴线",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "color": { "type": "string", "default": "#cccccc" },
            "width": { "type": "number", "default": 1 }
          }
        },
        "axisLabel": {
          "type": "object",
          "description": "轴标签",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "fontSize": { "type": "number", "default": 12 },
            "color": { "type": "string", "default": "#999999" },
            "fontWeight": { "type": "string", "default": "normal" },
            "fontFamily": { "type": "string", "default": "Microsoft YaHei" }
          }
        },
        "axisTick": {
          "type": "object",
          "description": "刻度线",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "length": { "type": "number", "default": 5 },
            "color": { "type": "string", "default": "#cccccc" }
          }
        },
        "splitLine": {
          "type": "object",
          "description": "网格线",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "color": { "type": "string", "default": "#eeeeee" },
            "width": { "type": "number", "default": 1 },
            "type": { "type": "string", "enum": ["solid", "dashed", "dotted"], "default": "dashed" }
          }
        }
      }
    },
    "legend": {
      "description": "图例配置",
      "properties": {
        "show": { "type": "boolean", "default": true },
        "position": {
          "type": "string",
          "enum": ["top", "bottom", "left", "right"],
          "default": "top"
        },
        "textStyle": {
          "type": "object",
          "properties": {
            "fontSize": { "type": "number", "default": 12 },
            "color": { "type": "string", "default": "#666666" },
            "fontWeight": { "type": "string", "default": "normal" }
          }
        },
        "itemGap": { "type": "number", "description": "图例间距", "default": 16 }
      }
    },
    "tooltip": {
      "description": "提示框配置",
      "properties": {
        "show": { "type": "boolean", "default": true },
        "trigger": {
          "type": "string",
          "enum": ["item"],
          "default": "item"
        },
        "backgroundColor": { "type": "string", "default": "rgba(50, 50, 50, 0.7)" },
        "borderColor": { "type": "string", "default": "transparent" },
        "textStyle": {
          "type": "object",
          "properties": {
            "fontSize": { "type": "number", "default": 12 },
            "color": { "type": "string", "default": "#ffffff" }
          }
        }
      }
    },
    "series": {
      "description": "系列(气泡)配置",
      "properties": {
        "sizeRange": {
          "type": "[number, number]",
          "description": "气泡大小范围 [最小px, 最大px]",
          "default": [10, 60]
        },
        "colors": {
          "type": "string[]",
          "description": "颜色列表",
          "default": ["#5470c6", "#91cc75", "#fac858", "#ee6666", "#73c0de", "#3ba272"]
        },
        "opacity": {
          "type": "number",
          "description": "气泡透明度(0-1)",
          "default": 0.7
        },
        "borderWidth": {
          "type": "number",
          "description": "气泡边框宽度(px)",
          "default": 1
        },
        "borderColor": {
          "type": "string",
          "description": "气泡边框颜色(空=跟随填充色)",
          "default": ""
        },
        "shape": {
          "type": "string",
          "description": "气泡形状",
          "enum": ["circle", "rect", "triangle", "diamond"],
          "default": "circle"
        },
        "label": {
          "type": "object",
          "description": "气泡标签",
          "properties": {
            "show": { "type": "boolean", "default": false },
            "content": {
              "type": "string",
              "description": "标签内容",
              "enum": ["name", "value", "x", "y", "size"],
              "default": "name"
            },
            "fontSize": { "type": "number", "default": 11 },
            "color": { "type": "string", "default": "#333333" },
            "fontWeight": { "type": "string", "default": "normal" }
          }
        },
        "emphasis": {
          "type": "object",
          "description": "高亮状态配置",
          "properties": {
            "scale": { "type": "number", "description": "高亮缩放比例", "default": 1.2 },
            "borderWidth": { "type": "number", "default": 2 },
            "shadowBlur": { "type": "number", "description": "阴影模糊大小", "default": 10 }
          }
        }
      }
    },
    "animation": {
      "description": "动画配置",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "duration": { "type": "number", "description": "动画时长(ms)", "default": 1000 },
        "easing": {
          "type": "string",
          "enum": ["linear", "cubicOut", "elasticOut", "bounceOut"],
          "default": "cubicOut"
        }
      }
    }
  },
  "behaviors": [
    {
      "name": "气泡单击",
      "desc": "鼠标点击气泡时触发",
      "method": "click",
      "paramsList": [
        { "name": "x", "desc": "点击气泡的X轴值", "type": "number" },
        { "name": "y", "desc": "点击气泡的Y轴值", "type": "number" },
        { "name": "size", "desc": "点击气泡的大小值", "type": "number" },
        { "name": "name", "desc": "点击气泡的分类名", "type": "string" }
      ]
    },
    {
      "name": "图例点击",
      "desc": "点击图例项时触发",
      "method": "legendClick",
      "paramsList": [
        { "name": "name", "desc": "图例名称", "type": "string" },
        { "name": "selected", "desc": "当前图例选中状态", "type": "boolean" }
      ]
    }
  ],
  "datasetFields": [
    {
      "name": "xField",
      "desc": "X轴数值字段",
      "required": true,
      "multiple": false
    },
    {
      "name": "yField",
      "desc": "Y轴数值字段",
      "required": true,
      "multiple": false
    },
    {
      "name": "sizeField",
      "desc": "气泡大小映射字段",
      "required": false,
      "multiple": false
    },
    {
      "name": "colorField",
      "desc": "颜色分组/映射字段",
      "required": false,
      "multiple": false
    },
    {
      "name": "nameField",
      "desc": "数据项名称字段",
      "required": false,
      "multiple": false
    }
  ]
}
