{
  "componentName": "DrPieChart",
  "title": "饼图",
  "description": "饼图通过扇形区块展示各分类数据占比关系。支持环形图、玫瑰图、中心内容展示、标签引导线、小数合并等高级功能。适用于展示数据的构成和占比分析。",
  "defaultSize": {
    "w": 350,
    "h": 350
  },
  "propsInterface": {
    "global": {
      "description": "全局配置",
      "properties": {
        "padding": {
          "type": "[number, number, number, number]",
          "description": "图表内边距 [上, 右, 下, 左] (px)",
          "default": [20, 20, 20, 20]
        }
      }
    },
    "pie": {
      "description": "饼图布局配置",
      "properties": {
        "innerRadius": {
          "type": "number",
          "description": "内半径百分比(0=饼图, >0=环形图)",
          "default": 0,
          "min": 0,
          "max": 90
        },
        "outerRadius": {
          "type": "number",
          "description": "外半径百分比",
          "default": 75,
          "min": 10,
          "max": 100
        },
        "center": {
          "type": "[string, string]",
          "description": "中心位置 [x%, y%]",
          "default": ["50%", "50%"]
        },
        "startAngle": {
          "type": "number",
          "description": "起始角度(度)",
          "default": 90
        },
        "roseType": {
          "type": "string | false",
          "description": "玫瑰图模式",
          "enum": [false, "radius", "area"],
          "default": false
        },
        "borderColor": {
          "type": "string",
          "description": "扇形边框颜色",
          "default": "#ffffff"
        },
        "borderWidth": {
          "type": "number",
          "description": "扇形边框宽度(px)",
          "default": 1
        },
        "borderRadius": {
          "type": "number",
          "description": "扇形圆角(px)",
          "default": 0
        }
      }
    },
    "centerContent": {
      "description": "中心内容配置（仅环形图有效，innerRadius > 0 时显示）",
      "properties": {
        "show": { "type": "boolean", "description": "是否显示中心内容", "default": false },
        "type": {
          "type": "string",
          "description": "内容类型",
          "enum": ["text", "image"],
          "default": "text"
        },
        "title": {
          "type": "object",
          "description": "标题配置",
          "properties": {
            "text": { "type": "string", "description": "标题文本", "default": "总计" },
            "fontSize": { "type": "number", "default": 14 },
            "color": { "type": "string", "default": "#999999" },
            "fontWeight": { "type": "string", "default": "normal" },
            "offsetY": { "type": "number", "description": "垂直偏移(px)", "default": -10 }
          }
        },
        "value": {
          "type": "object",
          "description": "数值配置",
          "properties": {
            "field": { "type": "string", "description": "取值字段(空=总和)", "default": "" },
            "fontSize": { "type": "number", "default": 24 },
            "color": { "type": "string", "default": "#333333" },
            "fontWeight": { "type": "string", "default": "bold" },
            "offsetY": { "type": "number", "description": "垂直偏移(px)", "default": 10 },
            "format": {
              "type": "string",
              "enum": ["default", "integer", "float1", "float2", "percent", "percent1", "thousand", "thousand1"],
              "default": "default"
            },
            "prefix": { "type": "string", "description": "前缀", "default": "" },
            "suffix": { "type": "string", "description": "后缀", "default": "" }
          }
        },
        "image": {
          "type": "object",
          "description": "图片配置(type=image时有效)",
          "properties": {
            "url": { "type": "string", "description": "图片URL", "default": "" },
            "width": { "type": "number", "description": "图片宽度(px)", "default": 40 },
            "height": { "type": "number", "description": "图片高度(px)", "default": 40 }
          }
        }
      }
    },
    "label": {
      "description": "标签配置",
      "properties": {
        "show": { "type": "boolean", "description": "是否显示标签", "default": true },
        "position": {
          "type": "string",
          "description": "标签位置",
          "enum": ["inside", "outside", "spider"],
          "default": "outside"
        },
        "content": {
          "type": "string",
          "description": "标签内容格式",
          "enum": ["name", "value", "percent", "name+value", "name+percent"],
          "default": "name+percent"
        },
        "fontSize": { "type": "number", "default": 12 },
        "color": { "type": "string", "description": "标签颜色(空=跟随扇形)", "default": "" },
        "fontWeight": { "type": "string", "default": "normal" },
        "guideLine": {
          "type": "object",
          "description": "引导线配置(position=outside/spider时有效)",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "length": { "type": "number", "description": "引导线长度(px)", "default": 15 },
            "length2": { "type": "number", "description": "第二段引导线长度(px,仅spider)", "default": 20 },
            "lineWidth": { "type": "number", "default": 1 },
            "color": { "type": "string", "description": "引导线颜色(空=跟随扇形)", "default": "" }
          }
        }
      }
    },
    "legend": {
      "description": "图例配置",
      "properties": {
        "show": { "type": "boolean", "default": true },
        "position": {
          "type": "string",
          "enum": ["top", "bottom", "left", "right"],
          "default": "bottom"
        },
        "textStyle": {
          "type": "object",
          "properties": {
            "fontSize": { "type": "number", "default": 12 },
            "color": { "type": "string", "default": "#666666" },
            "fontWeight": { "type": "string", "default": "normal" }
          }
        },
        "itemGap": { "type": "number", "description": "图例间距", "default": 16 }
      }
    },
    "tooltip": {
      "description": "提示框配置",
      "properties": {
        "show": { "type": "boolean", "default": true },
        "trigger": {
          "type": "string",
          "enum": ["item"],
          "default": "item"
        },
        "backgroundColor": { "type": "string", "default": "rgba(50, 50, 50, 0.7)" },
        "borderColor": { "type": "string", "default": "transparent" },
        "textStyle": {
          "type": "object",
          "properties": {
            "fontSize": { "type": "number", "default": 12 },
            "color": { "type": "string", "default": "#ffffff" }
          }
        },
        "showPercent": { "type": "boolean", "description": "是否显示占比", "default": true }
      }
    },
    "series": {
      "description": "系列配置",
      "properties": {
        "colors": {
          "type": "string[]",
          "description": "颜色列表",
          "default": ["#5470c6", "#91cc75", "#fac858", "#ee6666", "#73c0de", "#3ba272", "#fc8452", "#9a60b4"]
        },
        "selectedMode": {
          "type": "string | false",
          "description": "选中模式",
          "enum": [false, "single", "multiple"],
          "default": false
        },
        "selectedOffset": {
          "type": "number",
          "description": "选中偏移距离(px)",
          "default": 10
        },
        "minAngle": {
          "type": "number",
          "description": "最小扇形角度(度，防止小数据不可见)",
          "default": 0
        },
        "merge": {
          "type": "object",
          "description": "小数合并配置",
          "properties": {
            "enabled": { "type": "boolean", "description": "是否启用小数合并", "default": false },
            "maxCount": { "type": "number", "description": "最大展示切片数量", "default": 10 },
            "mergeLabel": { "type": "string", "description": "合并后的标签名", "default": "其他" }
          }
        }
      }
    },
    "animation": {
      "description": "动画配置",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "duration": { "type": "number", "description": "动画时长(ms)", "default": 1000 },
        "easing": {
          "type": "string",
          "enum": ["linear", "cubicOut", "elasticOut", "bounceOut"],
          "default": "cubicOut"
        }
      }
    }
  },
  "behaviors": [
    {
      "name": "扇形单击",
      "desc": "鼠标点击饼图扇形时触发",
      "method": "click",
      "paramsList": [
        { "name": "name", "desc": "点击扇形的分类名称", "type": "string" },
        { "name": "value", "desc": "点击扇形的数值", "type": "number" },
        { "name": "percent", "desc": "点击扇形的占比(%)", "type": "number" }
      ]
    },
    {
      "name": "图例点击",
      "desc": "点击图例项时触发",
      "method": "legendClick",
      "paramsList": [
        { "name": "name", "desc": "图例名称", "type": "string" },
        { "name": "selected", "desc": "当前图例选中状态", "type": "boolean" }
      ]
    }
  ],
  "datasetFields": [
    {
      "name": "nameField",
      "desc": "分类名称字段（维度）",
      "required": true,
      "multiple": false
    },
    {
      "name": "valueField",
      "desc": "数值字段（指标）",
      "required": true,
      "multiple": false
    }
  ]
}
