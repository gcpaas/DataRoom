{
  "componentName": "DrAreaChart",
  "title": "区域图",
  "description": "区域图（面积图）是折线图的延伸，通过折线与坐标轴之间的填充区域展示数据变化趋势和量级。支持堆叠、渐变填充、曲线平滑等功能，适合展示多维数据随时间的变化趋势。",
  "defaultSize": {
    "w": 400,
    "h": 300
  },
  "propsInterface": {
    "global": {
      "description": "全局配置",
      "properties": {
        "padding": {
          "type": "[number, number, number, number]",
          "description": "图表内边距 [上, 右, 下, 左] (px)",
          "default": [40, 20, 30, 40]
        }
      }
    },
    "xAxis": {
      "description": "X轴配置",
      "properties": {
        "show": { "type": "boolean", "description": "是否显示", "default": true },
        "type": {
          "type": "string",
          "description": "数据类型",
          "enum": ["category", "time", "value"],
          "default": "category"
        },
        "axisLine": {
          "type": "object",
          "description": "轴线",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "color": { "type": "string", "default": "#cccccc" },
            "width": { "type": "number", "default": 1 }
          }
        },
        "axisLabel": {
          "type": "object",
          "description": "轴标签",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "fontSize": { "type": "number", "default": 12 },
            "color": { "type": "string", "default": "#999999" },
            "fontWeight": { "type": "string", "default": "normal" },
            "fontFamily": { "type": "string", "default": "Microsoft YaHei" },
            "rotate": { "type": "number", "description": "旋转角度", "default": 0 }
          }
        },
        "axisTick": {
          "type": "object",
          "description": "刻度线",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "length": { "type": "number", "default": 5 },
            "color": { "type": "string", "default": "#cccccc" }
          }
        },
        "splitLine": {
          "type": "object",
          "description": "网格线",
          "properties": {
            "show": { "type": "boolean", "default": false },
            "color": { "type": "string", "default": "#eeeeee" },
            "width": { "type": "number", "default": 1 },
            "type": { "type": "string", "enum": ["solid", "dashed", "dotted"], "default": "dashed" }
          }
        }
      }
    },
    "yAxis": {
      "description": "Y轴配置",
      "properties": {
        "show": { "type": "boolean", "description": "是否显示", "default": true },
        "name": { "type": "string", "description": "轴名称", "default": "" },
        "range": {
          "type": "object",
          "description": "显示范围",
          "properties": {
            "auto": { "type": "boolean", "default": true },
            "min": { "type": "number", "default": 0 },
            "max": { "type": "number", "default": 100 }
          }
        },
        "axisLine": {
          "type": "object",
          "description": "轴线",
          "properties": {
            "show": { "type": "boolean", "default": false },
            "color": { "type": "string", "default": "#cccccc" },
            "width": { "type": "number", "default": 1 }
          }
        },
        "axisLabel": {
          "type": "object",
          "description": "轴标签",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "fontSize": { "type": "number", "default": 12 },
            "color": { "type": "string", "default": "#999999" },
            "fontWeight": { "type": "string", "default": "normal" },
            "fontFamily": { "type": "string", "default": "Microsoft YaHei" }
          }
        },
        "axisTick": {
          "type": "object",
          "description": "刻度线",
          "properties": {
            "show": { "type": "boolean", "default": false },
            "length": { "type": "number", "default": 5 },
            "color": { "type": "string", "default": "#cccccc" }
          }
        },
        "splitLine": {
          "type": "object",
          "description": "网格线",
          "properties": {
            "show": { "type": "boolean", "default": true },
            "color": { "type": "string", "default": "#eeeeee" },
            "width": { "type": "number", "default": 1 },
            "type": { "type": "string", "enum": ["solid", "dashed", "dotted"], "default": "dashed" }
          }
        }
      }
    },
    "legend": {
      "description": "图例配置",
      "properties": {
        "show": { "type": "boolean", "default": true },
        "position": {
          "type": "string",
          "enum": ["top", "bottom", "left", "right"],
          "default": "top"
        },
        "textStyle": {
          "type": "object",
          "properties": {
            "fontSize": { "type": "number", "default": 12 },
            "color": { "type": "string", "default": "#666666" },
            "fontWeight": { "type": "string", "default": "normal" }
          }
        },
        "itemGap": { "type": "number", "description": "图例间距", "default": 16 }
      }
    },
    "tooltip": {
      "description": "提示框配置",
      "properties": {
        "show": { "type": "boolean", "default": true },
        "trigger": {
          "type": "string",
          "enum": ["axis", "item"],
          "default": "axis"
        },
        "backgroundColor": { "type": "string", "default": "rgba(50, 50, 50, 0.7)" },
        "borderColor": { "type": "string", "default": "transparent" },
        "textStyle": {
          "type": "object",
          "properties": {
            "fontSize": { "type": "number", "default": 12 },
            "color": { "type": "string", "default": "#ffffff" }
          }
        }
      }
    },
    "series": {
      "description": "系列(区域)配置",
      "properties": {
        "displayMode": {
          "type": "string",
          "description": "区域形式",
          "enum": ["normal", "stack"],
          "default": "normal"
        },
        "lineType": {
          "type": "string",
          "description": "展示形式",
          "enum": ["line", "smooth"],
          "default": "line"
        },
        "lineWidth": {
          "type": "number",
          "description": "折线粗细(px)",
          "default": 2
        },
        "lineStyle": {
          "type": "string",
          "description": "折线线型",
          "enum": ["solid", "dashed", "dotted"],
          "default": "solid"
        },
        "colors": {
          "type": "string[]",
          "description": "颜色列表",
          "default": ["#5470c6", "#91cc75", "#fac858", "#ee6666", "#73c0de", "#3ba272"]
        },
        "areaStyle": {
          "type": "object",
          "description": "填充区域样式",
          "properties": {
            "opacity": {
              "type": "number",
              "description": "区域填充透明度(0-1)",
              "default": 0.6
            },
            "gradient": {
              "type": "object",
              "description": "渐变配置",
              "properties": {
                "enabled": { "type": "boolean", "description": "是否启用渐变", "default": true },
                "topOpacity": { "type": "number", "description": "顶部透明度(0-1)", "default": 0.6 },
                "bottomOpacity": { "type": "number", "description": "底部透明度(0-1)", "default": 0.05 }
              }
            }
          }
        },
        "symbol": {
          "type": "object",
          "description": "数据点标记",
          "properties": {
            "show": { "type": "boolean", "description": "是否显示数据点", "default": false },
            "type": {
              "type": "string",
              "enum": ["circle", "rect", "triangle", "diamond", "none"],
              "default": "circle"
            },
            "size": { "type": "number", "description": "标记大小(px)", "default": 4 },
            "borderWidth": { "type": "number", "default": 1 }
          }
        },
        "label": {
          "type": "object",
          "description": "数据标签",
          "properties": {
            "show": { "type": "boolean", "default": false },
            "position": {
              "type": "string",
              "enum": ["top", "bottom", "inside"],
              "default": "top"
            },
            "fontSize": { "type": "number", "default": 12 },
            "color": { "type": "string", "default": "#333333" },
            "fontWeight": { "type": "string", "default": "normal" }
          }
        },
        "connectNulls": {
          "type": "boolean",
          "description": "是否连接空值数据点",
          "default": false
        }
      }
    },
    "animation": {
      "description": "动画配置",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "duration": { "type": "number", "description": "动画时长(ms)", "default": 1000 },
        "easing": {
          "type": "string",
          "enum": ["linear", "cubicOut", "elasticOut", "bounceOut"],
          "default": "cubicOut"
        }
      }
    }
  },
  "behaviors": [
    {
      "name": "数据点单击",
      "desc": "鼠标点击区域图数据点时触发",
      "method": "click",
      "paramsList": [
        { "name": "x", "desc": "点击数据点的类目值", "type": "string" },
        { "name": "y", "desc": "点击数据点的数值", "type": "number" },
        { "name": "seriesName", "desc": "点击数据点的系列名", "type": "string" }
      ]
    },
    {
      "name": "区域单击",
      "desc": "鼠标点击填充区域时触发",
      "method": "areaClick",
      "paramsList": [
        { "name": "seriesName", "desc": "点击区域的系列名", "type": "string" }
      ]
    },
    {
      "name": "图例点击",
      "desc": "点击图例项时触发",
      "method": "legendClick",
      "paramsList": [
        { "name": "name", "desc": "图例名称", "type": "string" },
        { "name": "selected", "desc": "当前图例选中状态", "type": "boolean" }
      ]
    }
  ],
  "datasetFields": [
    {
      "name": "xField",
      "desc": "X轴/类目字段（维度）",
      "required": true,
      "multiple": false
    },
    {
      "name": "yField",
      "desc": "Y轴/数值字段（指标）",
      "required": true,
      "multiple": true
    },
    {
      "name": "seriesField",
      "desc": "系列分组字段",
      "required": false,
      "multiple": false
    }
  ]
}
